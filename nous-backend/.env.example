# NOUS backend env. Copy to .env for local dev.

ENVIRONMENT=dev
LOG_LEVEL=INFO

# Supabase
SUPABASE_URL=https://ssibcqwsaycnlzlxzked.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
# Optional. Backend will use service_role if present (bypasses RLS).
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Gemini
GEMINI_API_KEY=AIza...
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash
EMBED_DIM=768

# Ranking — PRD §4 defaults
DECAY_LAMBDA_YEAR=0.21072
BACKLINK_THRESHOLD=3
SEMANTIC_SEARCH_DEFAULT_LIMIT=12

# Synthesis tuning
SYNTHESIS_MAX_CONTEXT_ATOMS=12
SYNTHESIS_MAX_TOKENS=1024
SYNTHESIS_TEMPERATURE=0.4

# Pushback tuning
PUSHBACK_RECENT_WINDOW_DAYS=14
PUSHBACK_MAX_ATOMS=30
PUSHBACK_MAX_TOKENS=600
PUSHBACK_TEMPERATURE=0.5

# CORS — tighten in prod
CORS_ALLOW_ORIGINS=["*"]
